store-dir=/tmp/.pnpm-store
virtual-store-dir=/tmp/solarflow-dashboard/.pnpm
# Flat node_modules so Vercel's serverless function tracer (nft) resolves
# pnpm-symlinked deps like @supabase/supabase-js. Without this, dash functions
# crash at runtime with module-not-found (FUNCTION_INVOCATION_FAILED).
node-linker=hoisted
