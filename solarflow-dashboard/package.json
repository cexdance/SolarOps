{
  "name": "react_repo",
  "private": true,
  "version": "1.7.5.3",
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "pnpm install --prefer-offline && vite",
    "check-env": "node scripts/check-env.mjs",
    "build": "node scripts/check-env.mjs && rm -rf node_modules/.vite-temp && tsc -b && vite build",
    "build:prod": "node scripts/check-env.mjs && rm -rf node_modules/.vite-temp && tsc -b && BUILD_MODE=prod vite build",
    "lint": "pnpm install --prefer-offline && eslint .",
    "preview": "pnpm install --prefer-offline && vite preview",
    "install-deps": "pnpm install --prefer-offline",
    "snap-ui": "node scripts/capture-screens.mjs",
    "clean": "rm -rf node_modules .pnpm-store pnpm-lock.yaml && pnpm store prune",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.2",
    "date-fns": "^3.0.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.364.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "recharts": "^2.12.4",
    "resend": "^6.11.0",
    "sonner": "^1.7.2",
    "tailwindcss-animate": "^1.0.7",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@playwright/test": "^1.61.0",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.10.7",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/react-router-dom": "^5",
    "@vercel/node": "^5.6.15",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/ui": "^4.1.7",
    "autoprefixer": "10.4.20",
    "dotenv": "^17.4.2",
    "eslint": "^9.15.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "globals": "^15.12.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "postcss": "8.4.49",
    "tailwindcss": "v3.4.16",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.15.0",
    "vite": "~6.3.6",
    "vite-plugin-source-identifier": "1.1.2",
    "vitest": "^4.1.7"
  }
}
